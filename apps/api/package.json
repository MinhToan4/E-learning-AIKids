{
  "name": "@aikids/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-generated.mjs",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:reset": "prisma db push --force-reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "db:setup:reset": "prisma generate && prisma db push --force-reset && tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "firebase:check": "tsx scripts/firebase-check.ts",
    "worker:push": "tsx src/workers/push.worker.ts"
  },
  "dependencies": {
    "@aikids/domain": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.10.1",
    "@vidtory/ai-sdk": "file:../../packages/vidtory-ai-sdk",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.80.10",
    "dotenv": "^16.5.0",
    "fastify": "^5.4.0",
    "firebase-admin": "^14.2.0",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.11.1",
    "nanoid": "^3.3.16",
    "nodemailer": "^9.0.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
