# Core server (never commit real secrets)
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=10
# Required only for integration tests. Must identify a different database from DATABASE_URL.
TEST_DATABASE_URL=postgresql://USER:PASSWORD@TEST_HOST:6543/aikids_test?pgbouncer=true&connection_limit=5
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false

# Shared cache/rate limiter/queues. Required for horizontally scaled production.
REDIS_URL=redis://localhost:6379
GLOBAL_RATE_LIMIT_MAX=600
GENERATION_RATE_LIMIT_MAX=12
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Firebase Admin (base64(JSON); inject through a secret manager, never commit a real value)
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=storymee-35093
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
# Leave empty until the bucket has actually been provisioned.
FIREBASE_STORAGE_BUCKET=

# Public Firebase web configuration (safe to return to the browser)
FIREBASE_WEB_API_KEY=AIzaSyBFQJ_4go2JC_vIrLkElkZgk2eBCMyn2qs
FIREBASE_WEB_AUTH_DOMAIN=storymee-35093.firebaseapp.com
FIREBASE_WEB_MESSAGING_SENDER_ID=316338904764
FIREBASE_WEB_APP_ID=1:316338904764:web:c52e794bf4723fcffcbab9
FIREBASE_WEB_VAPID_KEY=
# Enable only after VAPID/native FCM is configured and push workers are running.
FIREBASE_PUSH_ENABLED=false
