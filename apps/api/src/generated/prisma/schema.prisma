// =============================================================================
// AI Kids Creator Academy — Prisma Schema
// PostgreSQL (Supabase) — snake_case tables, PascalCase models
// Date: 2026-07-20
// =============================================================================

generator client {
  provider = "prisma-client-js"
  // Isolated path avoids Windows EPERM locks on hoisted root node_modules
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── A. CORE IDENTITY ─────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role         String // student | parent | teacher | admin
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  pinHash      String?  @map("pin_hash")
  nickname     String?
  avatarId     String?  @map("avatar_id")
  level        Int      @default(1)
  xp           Int      @default(0)
  onboarded    Boolean  @default(false)
  goal         String?
  active       Boolean  @default(true)
  parentId     String?  @map("parent_id") @db.Uuid
  classId      String?  @map("class_id") @db.Uuid
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  // Self-references
  parent   User?  @relation("ParentChildren", fields: [parentId], references: [id])
  children User[] @relation("ParentChildren")

  // FK to classroom
  class ClassRoom? @relation("StudentClass", fields: [classId], references: [id])

  // Relations
  sessions       Session[]
  enrollments    Enrollment[]
  questProgress  QuestProgress[]
  assets         Asset[]
  projects       Project[]
  approvalsMade  Approval[]      @relation("Approver")
  approvalsOwned Approval[]      @relation("ChildApprovals")
  taughtClasses  ClassRoom[]     @relation("TeacherClasses")
  achievements   Achievement[]
  streak         DailyStreak?
  notifications  Notification[]
  parentProfile  ParentProfile?
  teacherProfile TeacherProfile?

  @@index([role, active])
  @@map("users")
}

model ParentProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  phone             String?
  preferredLanguage String   @default("vi") @map("preferred_language")
  notificationPrefs Json     @default("{}") @map("notification_prefs")
  maxChildren       Int      @default(5) @map("max_children")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parent_profiles")
}

model TeacherProfile {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  displayName        String?  @map("display_name")
  bio                String?
  subjects           String[] @default([])
  languages          String[] @default(["vi"])
  verificationStatus String   @default("none") @map("verification_status")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_profiles")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ClassRoom {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String   @unique
  teacherId String   @map("teacher_id") @db.Uuid
  status    String   @default("active")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  teacher  User   @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  students User[] @relation("StudentClass")

  @@index([teacherId])
  @@map("classrooms")
}

// ── B. CURRICULUM & LEARNING ─────────────────────────────────

model Course {
  id            String   @id // stable slug e.g. l1-k1-the-gioi
  title         String
  shortTitle    String   @map("short_title")
  tagline       String
  description   String
  coverFrom     String   @map("cover_from")
  coverTo       String   @map("cover_to")
  accent        String
  coverImage    String?  @map("cover_image")
  ageLabel      String   @map("age_label")
  /// L1 (6–8) | L2 (9–11) — curriculum track
  ageTrack      String   @default("L1") @map("age_track")
  /// K1…K6 within a track
  courseKey     String   @default("K1") @map("course_key")
  durationLabel String   @map("duration_label")
  productLabel  String   @map("product_label")
  status        String   @default("open")
  recommended   Boolean  @default(false)
  skillsJson    String   @map("skills_json")
  outcomesJson  String   @default("[]") @map("outcomes_json")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  quests      Quest[]
  enrollments Enrollment[]

  @@index([status, sortOrder])
  @@index([ageTrack, courseKey])
  @@map("courses")
}

model Quest {
  id             String  @id // stable slug e.g. meet-mascot
  courseId       String  @map("course_id")
  order          Int
  title          String
  skill          String
  reward         String
  duration       String
  hook           String
  accent         String
  icon           String  @default("star")
  practiceKind   String  @default("chips") @map("practice_kind")
  /// ideate (no AI) | produce (with AI) — curriculum stages
  stage          String  @default("ideate")
  videoUrl       String? @map("video_url")
  goalsJson      String  @map("goals_json")
  learnCardsJson String  @map("learn_cards_json")
  checkJson      String  @map("check_json")
  chipsJson      String? @map("chips_json")
  /// Curriculum stations: video → game → practice → check
  stationsJson   String? @map("stations_json")

  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress QuestProgress[]

  @@unique([courseId, order])
  @@index([courseId])
  @@map("quests")
}

model Enrollment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("enrollments")
}

model QuestProgress {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  questId   String   @map("quest_id")
  status    String   @default("locked")
  phase     String   @default("learn")
  stars     Int      @default(0)
  xpEarned  Int      @default(0) @map("xp_earned")
  dataJson  String?  @map("data_json")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([userId])
  @@map("quest_progress")
}

// ── C. PORTFOLIO & SOCIAL ────────────────────────────────────

model Asset {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  name      String
  questId   String?  @map("quest_id")
  thumbnail String
  private   Boolean  @default(true)
  metaJson  String?  @map("meta_json")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assets")
}

model Project {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  kind        String
  thumbnail   String
  private     Boolean  @default(true)
  shareStatus String   @default("private") @map("share_status")
  dataJson    String?  @map("data_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvals Approval[]

  @@index([userId])
  @@map("projects")
}

model Approval {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  childId     String   @map("child_id") @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  destination String   @default("family")
  status      String   @default("pending")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  child   User    @relation("ChildApprovals", fields: [childId], references: [id], onDelete: Cascade)
  parent  User?   @relation("Approver", fields: [parentId], references: [id])

  @@index([parentId, status])
  @@index([childId])
  @@map("approvals")
}

// ── D. GAMIFICATION ──────────────────────────────────────────

model Achievement {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("achievements")
}

model DailyStreak {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  current        Int      @default(0)
  longest        Int      @default(0)
  lastActiveDate String   @map("last_active_date")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_streaks")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ── E. SYSTEM SETTINGS (secrets encrypted at rest) ───────────

model SystemSetting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  /// AES-GCM ciphertext (base64) — never return raw to clients
  valueEnc  String?  @map("value_enc")
  /// Non-secret metadata JSON (e.g. last4, configuredAt)
  metaJson  String   @default("{}") @map("meta_json")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_settings")
}
