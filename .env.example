# Required in every deployed environment.
# Browser → StoryMee Hub → core domain APIs.
VITE_API_URL=https://dev-hub.storymee.com
VITE_APP_ENV=development

# Only change this when public media storage moves to another hostname.
VITE_STORAGE_PUBLIC_URL=https://storage.storymee.com

# Optional until Firebase is configured.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
