# ── PostgreSQL on StoryMee Ubuntu (server-only) ────────────
# Legacy apps/api uses its own aikids_db database on the same Ubuntu cluster.
# Do not point it at omni_db: its legacy `users` schema differs from core-account.
DATABASE_URL="postgresql://admin:[DB_PASSWORD]@omni-postgres:5432/aikids_db?connection_limit=5&pool_timeout=30"

# ── API ───────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

DEFAULT_PARENT_EMAIL=parent@demo.aikids.local
DEFAULT_CLASS_CODE=STAR-8
# Production / ClassDojo-Khan pattern: false — only parent creates children
# Dev may set true for quick demos
STUDENT_AUTO_CREATE=false

# ── Redis (optional — InMemory fallback if not set) ───────
# docker compose up redis -d  → then:
REDIS_URL=redis://localhost:6379

# ── Gmail SMTP (optional in dev — logs to console) ────────
# 1. Enable 2-Step Verification at https://myaccount.google.com/security
# 2. Create App Password → copy 16-char password below
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── App URL (for email links) ─────────────────────────────
APP_URL=http://localhost:5173

# ── StoryMee merge seams (optional) ───────────────────────
# Cookie Domain for cross-subdomain SSO (leave empty in local)
# COOKIE_DOMAIN=.storymee.com
# Gateway alias: /api/aikids/* proxies to /api/* (prefer edge rewrite in prod)
# API_ALIAS_PREFIX=/api/aikids

# All image/video generation uses Hub provider=auto → media rotation.
# The legacy API must never hold or call a Vidtory SDK key directly.
STORYMEE_HUB_URL=http://storymee-hub:5100
STORYMEE_STORAGE_URL=https://storage.storymee.com
HUB_API_KEY=replace-with-the-server-side-hub-key
HUB_MEDIA_PROVIDER=auto
HUB_MEDIA_TIMEOUT_MS=180000
HUB_MEDIA_POLL_MS=1000

# ── Google Sign-In (adults only; same email = one account) ─
# OAuth 2.0 Web Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Same value for the browser GIS button:
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Web ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
