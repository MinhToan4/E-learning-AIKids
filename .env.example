# ── PostgreSQL / Supabase (required — SQLite removed) ─────
# Dashboard → Project Settings → Database → Connection string (URI)
# Use pooler (6543) for serverless; direct (5432) for Prisma migrate if needed.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-DB-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"
# Do NOT use a second local Postgres if Supabase is already your database.

# ── Supabase JS (publishable / anon key — safe for browser) ─
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."
# Vite FE (same values):
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_..."

# ── API ───────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

DEFAULT_PARENT_EMAIL=parent@demo.aikids.local
DEFAULT_CLASS_CODE=STAR-8
# Production / ClassDojo-Khan pattern: false — only parent creates children
# Dev may set true for quick demos
STUDENT_AUTO_CREATE=false

# ── Redis (optional — InMemory fallback if not set) ───────
# docker compose up redis -d  → then:
REDIS_URL=redis://localhost:6379

# ── Gmail SMTP (optional in dev — logs to console) ────────
# 1. Enable 2-Step Verification at https://myaccount.google.com/security
# 2. Create App Password → copy 16-char password below
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── App URL (for email links) ─────────────────────────────
APP_URL=http://localhost:5173

# ── StoryMee merge seams (optional) ───────────────────────
# Cookie Domain for cross-subdomain SSO (leave empty in local)
# COOKIE_DOMAIN=.storymee.com
# Gateway alias: /api/aikids/* proxies to /api/* (prefer edge rewrite in prod)
# API_ALIAS_PREFIX=/api/aikids

# ── Web ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000

