# ── PostgreSQL / Supabase (required — SQLite removed) ─────
# Dashboard → Project Settings → Database → Connection string (URI)
# Use pooler (6543) for serverless; direct (5432) for Prisma migrate if needed.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-DB-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"
# Do NOT use a second local Postgres if Supabase is already your database.

# ── Supabase JS (publishable / anon key — safe for browser) ─
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."
# Vite FE (same values):
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_..."

# ── API ───────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

DEFAULT_PARENT_EMAIL=parent@demo.aikids.local
DEFAULT_CLASS_CODE=STAR-8
STUDENT_AUTO_CREATE=true

# ── Web ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
