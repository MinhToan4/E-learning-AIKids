rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function sameClass(classId) {
      return signedIn()
        && (request.auth.token.get('classId', '') == classId
          || classId in request.auth.token.get('classIds', []));
    }
    function ownsClass(classId) {
      return signedIn()
        && request.auth.token.role in ['teacher', 'admin']
        && (request.auth.token.role == 'admin'
          || get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId
             == request.auth.token.appUserId);
    }

    match /classrooms/{classId} {
      allow read: if sameClass(classId)
        || (signedIn()
          && request.auth.token.role in ['teacher', 'admin']
          && (request.auth.token.role == 'admin'
            || resource.data.teacherId == request.auth.token.appUserId));
      allow write: if false; // Firebase Admin projection only.

      match /events/{eventId} {
        allow read: if sameClass(classId) || ownsClass(classId);
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
